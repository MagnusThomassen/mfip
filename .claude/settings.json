{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py",
            "args": ["-3.12", "${CLAUDE_PROJECT_DIR}/.claude/hooks/git-guardrails.py"],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
