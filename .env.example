# MFIP — Environment variables template
#
# Copy this file to .env and fill in real values.
# .env is gitignored (.gitignore line 29) — never commit it.
#
# Last reviewed: 2026-05-15 (Session 15A close-out)

# ===========================================================================
# SMTP — Alert delivery via Gmail (used by mfip.alerts module, Phase 2 PR-B)
# ===========================================================================
# Gmail SMTP requires an app password, not the main account password.
# Generate at: Google Account → Security → 2-Step Verification → App passwords
# Requires 2FA enabled on the account.
MFIP_SMTP_HOST=smtp.gmail.com
MFIP_SMTP_PORT=587
MFIP_SMTP_USER=your.email@gmail.com
MFIP_SMTP_APP_PASSWORD=replace-with-16-char-app-password
MFIP_ALERT_RECIPIENT=recipient.email@example.com
